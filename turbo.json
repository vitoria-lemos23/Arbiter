{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "env": [
        "DATABASE_URL",
        "NEXT_PUBLIC_RPC_URL",
        "NEXT_PUBLIC_CHAIN_ID",
        "NEXT_PUBLIC_COUNTER_ADDRESS"
      ],
      "outputs": [
        ".next/**",
        "!.next/cache/**",
        "dist/**",
        "artifacts/**",
        "typechain-types/**"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "clean": {
      "cache": false
    }
  }
}
