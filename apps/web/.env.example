# Runtime database connection for the web app (used in-process by @arbiter/db
# via @arbiter/core). Keep in sync with packages/db/.env used by drizzle-kit.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/arbiter

# Counter contract integration (read/write via viem). Defaults below target a
# local Hardhat node (`hardhat node`) and its first prefunded dev account.
# COUNTER_PRIVATE_KEY is only needed for writes (the increment form).
RPC_URL=http://127.0.0.1:8545
CHAIN_ID=31337
COUNTER_ADDRESS=
COUNTER_PRIVATE_KEY=