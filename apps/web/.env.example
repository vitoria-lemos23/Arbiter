# Runtime database connection for the web app (used in-process by @arbiter/db
# via @arbiter/core). Keep in sync with packages/db/.env used by drizzle-kit.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/arbiter

# Counter contract integration. Reads happen on the server (viem); writes are
# signed in the browser by the user's wallet (wagmi), so no private key is
# needed here. NEXT_PUBLIC_* values are exposed to the browser — keep them
# public-only. Defaults target a local Hardhat node.
NEXT_PUBLIC_RPC_URL=http://127.0.0.1:8545
NEXT_PUBLIC_CHAIN_ID=31337
NEXT_PUBLIC_COUNTER_ADDRESS=

# TournamentFactory address for wallet-signed `createTournament` writes. Unset
# until the factory is deployed; the create form disables submit while empty.
NEXT_PUBLIC_FACTORY_ADDRESS=