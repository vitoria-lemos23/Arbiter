# Same Postgres as @arbiter/db; Ponder writes into its OWN schema (`ponder`,
# set by --schema in the npm scripts), read back by the app read-only.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/arbiter

# Chain + factory the indexer follows. Defaults target a local Hardhat node with
# a freshly deployed factory (see packages/contracts). INDEXER_FACTORY_ADDRESS is
# required — set it to the deployed TournamentFactory address.
INDEXER_RPC_URL=http://127.0.0.1:8545
INDEXER_CHAIN_ID=31337
INDEXER_START_BLOCK=0
INDEXER_FACTORY_ADDRESS=
